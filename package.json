    "urban-planning",
    "dhaka",
    "ai",
    "groq"
  ],
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.1.39",
    "@langchain/groq": "^1.2.0",
    "@turf/turf": "^7.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "langchain": "^1.3.1",
    "ws": "^8.16.0"
  },
  "optionalDependencies": {
    "ioredis": "^5.3.0"
  }
}
