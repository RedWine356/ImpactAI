{
  "name": "nagormind-backend",
  "version": "2.0.0",
  "description": "NagorMind — AI Urban Planning Advisor for Dhaka",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
