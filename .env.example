# NagorMind API Keys (all free tier)
GROQ_API_KEY=your_groq_api_key_here
WAQI_TOKEN=your_waqi_token_here
OWM_API_KEY=your_openweathermap_key_here
# Optional fallback order if a model is busy/unavailable
# GROQ_MODEL_CANDIDATES=llama-3.3-70b-versatile,llama-3.1-8b-instant

# Server
PORT=3000
NODE_ENV=development

# Redis (optional — uncomment only if you run: docker compose up -d)
# REDIS_URL=redis://localhost:6379
